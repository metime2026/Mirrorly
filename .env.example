# 复制为 .env.local（本地）或在 Vercel 项目 Settings → Environment Variables 中配置

# ── PostgreSQL（必填）────────────────────────────────────────────
# Vercel: 创建 Storage → Postgres，会自动注入 POSTGRES_URL
# Neon:   https://neon.tech 控制台复制连接串
POSTGRES_URL="postgresql://user:password@host/db?sslmode=require"

# 兼容别名（任选其一，migrate 脚本均支持）
# DATABASE_URL="postgresql://..."

# ── Gemini AI（必填，用于镜像观察与 Ask AI）────────────────────
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# GEMINI_MODEL="gemini-2.0-flash"

# ── 单用户访问密码（必填，登录页使用）────────────────────────────
MIRRORLY_PASSWORD="your-strong-password-here"

# ── 可选：用户展示信息 ───────────────────────────────────────────
# MIRRORLY_USER_ID="user_default"
# MIRRORLY_USER_EMAIL="you@example.com"
# MIRRORLY_USER_NICKNAME="Metime"

# ── 本地开发 API 端口（默认 3001，Vite 代理到此）────────────────
# API_PORT=3001
