{
  "name": "mirrorly",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx scripts/dev-api.ts",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "db:migrate": "tsx scripts/migrate.ts",
    "setup:vercel": "bash setup.sh",
    "setup:full": "tsx scripts/full-setup.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@neondatabase/serverless": "^0.10.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "postgres": "^3.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^41.0.0"
  },
  "description": "认知记录与反思对话工具。通过温和启发引导，AI 读取你的学识背景开展多轮反思，并自动提炼思维观察模式。",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metime2026/Mirrorly.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/metime2026/Mirrorly/issues"
  },
  "homepage": "https://github.com/metime2026/Mirrorly#readme"
}
